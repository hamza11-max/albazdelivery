# ============================================
# AL-baz Delivery Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string for Prisma (direct; not Accelerate)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/albazdelivery?schema=public

# Optional: second database for `prisma migrate dev` shadow DB on hosts that cannot auto-create DBs
# (e.g. Prisma Postgres / many cloud providers). Must not be the same DB as DATABASE_URL.
# SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/albazdelivery_shadow?schema=public

# ============================================
# NextAuth Configuration
# ============================================
# Secret key for NextAuth.js (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="oj6xGNTogXAzowpadvtBo3FJZ/ov5aNidmZNYBpkTS8="

# Base URL - must match the app's origin (per-app in .env.local or deployment)
# Development (per app):
#   customer: http://localhost:3000
#   vendor:   http://localhost:3001
#   driver:   http://localhost:3002
#   admin:    http://localhost:3003
# Production: https://customer.albazdelivery.com, https://vendor.albazdelivery.com, etc.
NEXTAUTH_URL="https://albazdelivery.vercel.app"

# ============================================
# OAuth Providers (Optional)
# ============================================
# Google OAuth (optional - for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Redis Configuration (Optional)
# ============================================
# For caching and rate limiting
# Option 1: Redis URL (for Upstash or similar)
REDIS_URL=redis://default:password@host:port
REDIS_TOKEN=your-redis-token

# Option 2: Redis Host/Port (for local Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# Option 3: Upstash Redis REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# Security Configuration
# ============================================
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,https://app.albazdelivery.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ============================================
# WhatsApp Cloud API (Meta) — vendor numbers per store
# ============================================
# Webhook verification (GET challenge) — set the same string in Meta Developer dashboard
WHATSAPP_VERIFY_TOKEN=your-random-verify-token
# App secret — used for X-Hub-Signature-256 on /api/webhooks/whatsapp and /api/webhooks/whatsapp/flow
WHATSAPP_APP_SECRET=your-meta-app-secret
# RSA private key PEM (newlines as \n) — decrypt Flow endpoint requests; upload matching public key in Meta
# WHATSAPP_FLOW_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
