{
  "name": "@albaz/vendor",
  "version": "1.1.0",
  "description": "AlBaz Vendor desktop app for store and order management",
  "author": "AlBaz Delivery",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:clean": "node -e \"const fs=require('fs');const p=require('path');const d=p.join(__dirname,'.next');if(fs.existsSync(d)){fs.rmSync(d,{recursive:true});console.log('Cleaned .next');}\" && next dev -p 3001",
    "build": "next build --webpack",
    "build:electron": "cross-env ELECTRON_BUILD=true next build --webpack",
    "start": "next start -p 3001",
    "electron": "electron .",
    "electron:dev": "npm run setup:icons && cross-env NODE_ENV=development electron .",
    "electron:dev:restaurant": "cross-env VENDOR_BUILD_FLAVOR=restaurant node scripts/write-bundled-flavor.js && npm run electron:dev",
    "electron:dev:retail": "cross-env VENDOR_BUILD_FLAVOR=retail node scripts/write-bundled-flavor.js && npm run electron:dev",
    "electron:dev:grocery": "cross-env VENDOR_BUILD_FLAVOR=grocery node scripts/write-bundled-flavor.js && npm run electron:dev",
    "electron:dev:other": "cross-env VENDOR_BUILD_FLAVOR=other node scripts/write-bundled-flavor.js && npm run electron:dev",
    "electron:clean": "node scripts/clean-dist.js",
    "electron:kill": "node -e \"const {execSync}=require('child_process');const p=require('path');try{if(process.platform==='win32')execSync('powershell -ExecutionPolicy Bypass -File '+p.join(__dirname,'scripts','kill-vendor-app.ps1'),{stdio:'ignore'});}catch(e){}\"",
    "electron:build": "npm run electron:kill && npm run electron:clean && node scripts/write-bundled-flavor.js && node scripts/clean-next.js && npm run build:electron && node scripts/copy-standalone-static.js && node scripts/copy-standalone-public.js && node scripts/copy-standalone-deps.js && node scripts/download-node-win.js && npm run electron:kill && node scripts/ensure-dist-unlocked.js && npm run setup:icons && npx electron-builder",
    "electron:build:win": "npm run electron:kill && npm run electron:clean && node scripts/write-bundled-flavor.js && node scripts/clean-next.js && npm run build:electron && node scripts/copy-standalone-static.js && node scripts/copy-standalone-public.js && node scripts/copy-standalone-deps.js && node scripts/download-node-win.js && npm run electron:kill && node scripts/ensure-dist-unlocked.js && npm run setup:icons && npx electron-builder --win",
    "electron:build:win:restaurant": "node scripts/electron-build-win-flavor.js restaurant",
    "electron:build:win:retail": "node scripts/electron-build-win-flavor.js retail",
    "electron:build:win:grocery": "node scripts/electron-build-win-flavor.js grocery",
    "electron:build:win:other": "node scripts/electron-build-win-flavor.js other",
    "electron:build:win:all-verticals": "node scripts/electron-build-all-flavors.js",
    "electron:build:vendor:desktop:restaurant": "npm run electron:build:win:restaurant",
    "electron:build:vendor:desktop:retail": "npm run electron:build:win:retail",
    "electron:build:vendor:desktop:grocery": "npm run electron:build:win:grocery",
    "electron:build:vendor:desktop:other": "npm run electron:build:win:other",
    "electron:build:vendor:desktop:all-verticals": "npm run electron:build:win:all-verticals",
    "electron:verify": "node scripts/verify-build.js",
    "setup:icons": "node scripts/setup-icons.js",
    "optimize:brand-logo": "node scripts/strip-albaz-logo-bg.mjs",
    "optimize:topbar-bird": "node scripts/process-topbar-bird-logo.mjs",
    "kill:port": "powershell -ExecutionPolicy Bypass -File scripts/kill-port.ps1",
    "restart:dev": "powershell -ExecutionPolicy Bypass -File scripts/restart-dev.ps1",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint . --ext .js,.jsx,.ts,.tsx --config .eslintrc.json --no-eslintrc",
    "type-check": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test jest --config ../../jest.config.ts",
    "test:watch": "cross-env NODE_ENV=test jest --config ../../jest.config.ts --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --config ../../jest.config.ts --coverage"
  },
  "dependencies": {
    "@albaz/auth": "*",
    "@albaz/shared": "*",
    "@albaz/ui": "*",
    "@next/env": "^16.0.7",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "better-sqlite3": "^12.4.6",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.454.0",
    "next": "^16.0.7",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-jsx": "^5.1.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.25.76"
  },
  "overrides": {
    "yauzl": ">=3.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.0",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "electron": "39.8.6",
    "electron-builder": "^26.0.12",
    "electron-updater": "^6.6.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5"
  },
  "build": {
    "extends": "./electron-builder.yml",
    "appId": "com.albaz.vendor",
    "productName": "AlBaz Vendor",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hamza11-max",
        "repo": "albazdelivery",
        "channel": "latest"
      }
    ]
  }
}
