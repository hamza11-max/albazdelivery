{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "next": [
        "../../node_modules/next"
      ],
      "@/hooks/*": [
        "../../hooks/*"
      ],
      "@/components/*": [
        "../../components/*"
      ],
      "@/lib/prisma": [
        "../../lib/prisma.ts"
      ],
      "@/lib/constants": [
        "../../lib/constants.ts"
      ],
      "@/generated/prisma/client": [
        "../../generated/prisma/client"
      ],
      "@/lib/types": [
        "../../lib/types.ts"
      ],
      "@/*": [
        "./*"
      ],
      "@/root/*": [
        "../../*"
      ],
      "@albaz/shared": [
        "../../packages/shared/src"
      ],
      "@albaz/ui": [
        "../../packages/ui/src"
      ],
      "@albaz/auth": [
        "../../packages/auth/src"
      ]
    },
    "jsx": "preserve"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../components/**/*",
    "../../hooks/**/*",
    "../../lib/**/*",
    "../../types/global.d.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "__tests__",
    "app/vendor/page-original-backup.tsx"
  ]
}
